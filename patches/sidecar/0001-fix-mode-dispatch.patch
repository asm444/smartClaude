-		defer logOut.(io.Closer).Close()
-	}
+	logOut := setupLogging("")
 
 	var err error
-	switch *mode {
+	switch mode {
 	case "daemon":
-		err = runDaemonMode(os.Args, logOut)
+		err = runDaemonMode(append([]string{os.Args[0]}, rest...), logOut)
 	case "ui":
 		err = runUI(logOut)
 	case "cli":
-		err = runCLI(os.Args, logOut)
