# 0001-fix-mode-dispatch.patch
#
# Base upstream: FreyreCorona/SideCar @ d356c2b
# Aplicar com:   git apply patches/sidecar/*.patch
#
# Bug 1: dispatch de -mode quebrado — o FlagSet do sub-parser recebia
# os.Args cru (com o -mode ja consumido) e abortava com 'flag provided but
# not defined: -mode'. Torna -mode daemon/-mode cli utilizaveis.
#
# Contexto completo: docs/historico/fork-sidecar-bugs.md

diff --git a/main.go b/main.go
index 85c7a1d..4a3f849 100644
--- a/main.go
+++ b/main.go
@@ -21,33 +21,34 @@ import (
 //	sidecar -mode daemon       → daemon
