+// loadRGB565PNG decodes a PNG file and converts it to the 240x240 RGB565
+// little-endian pixel format expected by core.BuildACF. The source image
+// must already be exactly 240x240 (the caller is expected to have resized
+// it) so this stays a pure format conversion, not a resampler.
+func loadRGB565PNG(path string) ([]byte, error) {
+	f, err := os.Open(path)
+	if err != nil {
+		return nil, err
+	}
+	defer f.Close()
+
+	img, _, err := image.Decode(f)
+	if err != nil {
+		return nil, fmt.Errorf("decode PNG: %w", err)
+	}
+
+	b := img.Bounds()
+	if b.Dx() != 240 || b.Dy() != 240 {
+		return nil, fmt.Errorf("image must be exactly 240x240, got %dx%d", b.Dx(), b.Dy())
+	}
+
+	out := make([]byte, core.ImageDataSize)
+	i := 0
+	for y := b.Min.Y; y < b.Max.Y; y++ {
+		for x := b.Min.X; x < b.Max.X; x++ {
+			r, g, bl, _ := img.At(x, y).RGBA()
+			// RGBA() returns 16-bit-per-channel values; take the high byte.
+			r5 := uint16(r>>8) >> 3
+			g6 := uint16(g>>8) >> 2
+			b5 := uint16(bl>>8) >> 3
+			px := (r5 << 11) | (g6 << 5) | b5
+			out[i] = byte(px)
+			out[i+1] = byte(px >> 8)
+			i += 2
+		}
+	}
+	return out, nil
+}
